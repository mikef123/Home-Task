/**
 * @param {number[]} prices
 * @return {number}
 */
var maxProfit = function (prices) {
    let lowerPrice = 188
    let profit = 0
    for (let price of prices) {
        if (price < lowerPrice) {
            lowerPrice = price;
        } else {
            if ((price - lowerPrice > profit) {
                profit = price - lowerPrice;
            }
        }
    }
    return profit
};
